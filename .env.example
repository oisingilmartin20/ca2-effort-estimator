# Copy to .env. OPENAI_API_KEY and ESTIMATOR_MODEL are required for the Streamlit estimator.

# --- Local LM Studio (recommended for offline / no cloud key) ---
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
ESTIMATOR_MODEL=olmo-3-7b-instruct

# --- Cloud (Groq, OpenAI, etc.) — uncomment and fill in instead ---
# OPENAI_API_KEY=<YOUR_API_KEY>
# ESTIMATOR_MODEL=llama-3.3-70b-versatile
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# TAWOS MySQL (used by scripts/analyze_tawos.py)
DATABASE_URL=mysql+pymysql://root@127.0.0.1/tawos

# Optional backlog CSV for the Streamlit app (defaults to data/tawos_sample.csv)
# TAWOS_DATA_PATH=data/tawos_balanced_train.csv

# Postgres pgvector store (used by scripts/generate_embeddings.py and MCP)
POSTGRES_URL=postgresql+psycopg://tawos:tawos@localhost:5432/tawos_vectors
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
TAWOS_RETRIEVAL_CSV=data/tawos_retrieval_corpus.csv
TAWOS_TRAIN_CSV=data/tawos_train_holdout.csv
SIMILAR_TICKETS_LIMIT=10

# OpenAI-compatible embeddings (set EMBEDDING_PROVIDER=openai)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536