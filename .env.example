# Copy to .env. If OPENAI_API_KEY is unset, the app uses a heuristic fallback.

# --- Local LM Studio (recommended for offline / no cloud key) ---
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
ESTIMATOR_MODEL=<model-id-from-lm-studio-api-usage>

# --- Cloud (Groq, OpenAI, etc.) — uncomment and fill in instead ---
# OPENAI_API_KEY=<YOUR_API_KEY>
# ESTIMATOR_MODEL=llama-3.3-70b-versatile
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# TAWOS MySQL (used by scripts/analyze_tawos.py)
DATABASE_URL=mysql+pymysql://root@127.0.0.1/tawos

# Optional backlog CSV for the Streamlit app (defaults to data/tawos_sample.csv)
# TAWOS_DATA_PATH=data/tawos_balanced_train.csv